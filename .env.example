# =============================================================================
# PDMS-Omni — Configuración de ejemplo
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo a .env:  cp .env.example .env
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subas el archivo .env al repositorio
#
# SEGURIDAD:
#   - JWT_SECRET debe ser aleatorio de al menos 32 bytes.
#     Genera uno con:  openssl rand -hex 32
#   - ADMIN_PASSWORD debe ser una contraseña segura (mínimo 12 caracteres,
#     mayúsculas, minúsculas, números y símbolos).
#   - CORS_ORIGINS=* NO debe usarse en producción. Lista los orígenes exactos.
#   - DB_TRUST_SERVER_CERTIFICATE=true deshabilita la validación TLS.
#     En producción, usa un certificado válido y cambia esto a false.
# =============================================================================

# ── Puerto Serial ─────────────────────────────────────────────────────────────
SERIAL_PORT=COM6
SERIAL_BAUDRATE=19200
SERIAL_TIMEOUT=2
SERIAL_MAX_FAILURES=5

# ── Base de Datos (sqlite | mssql | postgres) ─────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=1433          # MSSQL: 1433 | PostgreSQL: 5432
# DB_DATABASE=database.db
# DB_USERNAME=<CAMBIAR>
# DB_PASSWORD=<CAMBIAR>
# DB_TRUST_SERVER_CERTIFICATE=false   # true solo en entornos de desarrollo local

# ── Protocolo OMNI-ODI ────────────────────────────────────────────────────────
SRC_ADDR=11
DST_ADDR=1

# ── WebSocket / HTTP API ──────────────────────────────────────────────────────
# En producción, no uses 0.0.0.0 si el servidor no está detrás de un proxy
WS_HOST=127.0.0.1
WS_PORT=9001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista los orígenes exactos separados por coma. NO uses * en producción.
CORS_ORIGINS=http://localhost:5173,http://localhost:9001

# ── Captura de parámetros ─────────────────────────────────────────────────────
# CAPTURE_MODE: all | selected
CAPTURE_MODE=all
# CAPTURE_HANDLES acepta decimal y/o hex (ej: 1,2,0x0010)
CAPTURE_HANDLES=
# CAPTURE_NAMES usa internal_name separados por coma (case-insensitive)
CAPTURE_NAMES=

# ── Intervalos ────────────────────────────────────────────────────────────────
CYCLE_INTERVAL=1
# DB_SAVE_INTERVAL debe ser >= CYCLE_INTERVAL
DB_SAVE_INTERVAL=60
# true: solo guarda cuando el paciente esté en terapia (main_state = 2)
DB_SAVE_ONLY_ON_THERAPY=true

# ── Reintentos de inicialización del dispositivo serial ───────────────────────
DEVICE_INIT_RETRY_MAX_ATTEMPTS=10
DEVICE_INIT_RETRY_INTERVAL=5

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Directorio del dashboard compilado (opcional)
# Si no se define, se busca junto al binario o en ./dashboard-ts/dist/
DASHBOARD_DIR=

# ── Autenticación ─────────────────────────────────────────────────────────────
# Contraseña del administrador (solo se usa en el primer inicio)
# ⚠ CAMBIAR antes de producción
ADMIN_PASSWORD=<CAMBIAR>

# Secreto JWT — debe ser aleatorio y secreto
# Genera con: openssl rand -hex 32
# ⚠ CAMBIAR antes de producción
JWT_SECRET=<CAMBIAR>

# Expiración del token JWT en horas (por defecto: 24)
# JWT_EXPIRATION_HOURS=24
