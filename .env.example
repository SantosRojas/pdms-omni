# Configuración del Puerto Serial
SERIAL_PORT=COM8
SERIAL_BAUDRATE=19200
SERIAL_TIMEOUT=2
SERIAL_MAX_FAILURES=5

# Configuración de Base de Datos (sqlite | mssql | postgres)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_DATABASE=database.db
# DB_USERNAME=user
# DB_PASSWORD=password

# Configuración de Protocolo
SRC_ADDR=11
DST_ADDR=1

# WebSocket para dashboard
WS_HOST=127.0.0.1
WS_PORT=9001

# Captura de parámetros
CAPTURE_MODE=all
CAPTURE_HANDLES=
CAPTURE_NAMES=

# Intervalo de captura en segundos
CYCLE_INTERVAL=1
DB_SAVE_INTERVAL=60
DB_SAVE_ONLY_ON_THERAPY=true

# Reintentos de inicialización del dispositivo serial
DEVICE_INIT_RETRY_MAX_ATTEMPTS=10
DEVICE_INIT_RETRY_INTERVAL=5

# Directorio del dashboard (opcional)
DASHBOARD_DIR=

# Contraseña del administrador (requerida para primer inicio)
ADMIN_PASSWORD=cambiar-esta-contraseña

# Secreto JWT (requerido)
JWT_SECRET=cambiar-este-secreto-en-produccion

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:9001
